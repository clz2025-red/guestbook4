<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="guestbook">
	
	<!-- 방명록전체가져오기 -->
	<select id="selectList"  resultType="com.javaex.vo.GuestbookVO">
		select 	no,
				name,
				password,
		        content,
		        reg_date
		from guestbook
		order by reg_date desc
	</select>
	
		
	
